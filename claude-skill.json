{\n  \"name\": \"DeepSeek Vision Skill\",\n  \"id\": \"deepseek-claude-vision-skill\",\n  \"version\": \"0.1.0\",\n  \"description\": \"A Claude Code Skill for DeepSeek Vision image recognition. Supports image analysis, object detection, OCR, and code generation from UI designs.\",\n  \"author\": \"Tianci Liu\",\n  \"license\": \"MIT\",\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/Tianci-Liu-123/deepseek-claude-vision-skill.git\"\n  },\n  \"installation\": {\n    \"type\": \"package\",\n    \"method\": \"pip\",\n    \"requirements\": \"requirements.txt\"\n  },\n  \"dependencies\": [\n    \"requests>=2.31.0\",\n    \"python-dotenv>=1.0.0\",\n    \"anthropic>=0.21.0\",\n    \"loguru>=0.7.0\"\n  ],\n  \"environment\": {\n    \"required\": [\n      \"DEEPSEEK_API_KEY\"\n    ],\n    \"optional\": [\n      \"ANTHROPIC_API_KEY\",\n      \"DEEPSEEK_API_URL\",\n      \"LOG_LEVEL\",\n      \"DEBUG\",\n      \"REQUEST_TIMEOUT\",\n      \"MAX_RETRIES\",\n      \"MAX_IMAGE_SIZE\"\n    ]\n  },\n  \"tools\": [\n    {\n      \"name\": \"deepseek_image_recognition\",\n      \"type\": \"function\",\n      \"description\": \"Recognize and analyze image content using DeepSeek Vision model\",\n      \"module\": \"src.deepseek_vision\",\n      \"class\": \"DeepSeekVisionTool\",\n      \"methods\": [\n        {\n          \"name\": \"recognize_image\",\n          \"description\": \"Recognize a single image from URL or local path\",\n          \"parameters\": {\n            \"image_input\": {\n              \"type\": \"string\",\n              \"description\": \"Image URL or local file path\",\n              \"required\": true\n            },\n            \"prompt\": {\n              \"type\": \"string\",\n              \"description\": \"Recognition prompt to guide the model\",\n              \"required\": false,\n              \"default\": \"Please describe this image in detail\"\n            }\n          },\n          \"returns\": {\n            \"type\": \"string\",\n            \"description\": \"Image recognition result\"\n          }\n        },\n        {\n          \"name\": \"batch_recognize\",\n          \"description\": \"Batch recognize multiple images\",\n          \"parameters\": {\n            \"image_inputs\": {\n              \"type\": \"array\",\n              \"description\": \"List of image paths or URLs\",\n              \"required\": true\n            },\n            \"prompt\": {\n              \"type\": \"string\",\n              \"description\": \"Recognition prompt for all images\",\n              \"required\": false,\n              \"default\": \"Please describe this image\"\n            }\n          },\n          \"returns\": {\n            \"type\": \"array\",\n            \"description\": \"List of recognition results\"\n          }\n        }\n      ]\n    },\n    {\n      \"name\": \"deepseek_claude_vision_chat\",\n      \"type\": \"function\",\n      \"description\": \"Chat with Claude while recognizing images using DeepSeek Vision\",\n      \"module\": \"src.claude_adapter\",\n      \"class\": \"DeepSeekImageRecognitionAdapter\",\n      \"methods\": [\n        {\n          \"name\": \"chat_with_vision\",\n          \"description\": \"Chat with Claude using image recognition\",\n          \"parameters\": {\n            \"user_message\": {\n              \"type\": \"string\",\n              \"description\": \"User message that may include image references\",\n              \"required\": true\n            }\n          },\n          \"returns\": {\n            \"type\": \"string\",\n            \"description\": \"Claude's response\"\n          }\n        },\n        {\n          \"name\": \"direct_recognize\",\n          \"description\": \"Directly recognize an image without Claude\",\n          \"parameters\": {\n            \"image_url\": {\n              \"type\": \"string\",\n              \"description\": \"Image URL or local path\",\n              \"required\": true\n            },\n            \"prompt\": {\n              \"type\": \"string\",\n              \"description\": \"Recognition prompt\",\n              \"required\": false,\n              \"default\": \"Please describe this image in detail\"\n            }\n          },\n          \"returns\": {\n            \"type\": \"string\",\n            \"description\": \"Recognition result\"\n          }\n        }\n      ]\n    }\n  ],\n  \"cli\": {\n    \"enabled\": true,\n    \"entry_point\": \"run_vision.py\",\n    \"commands\": [\n      {\n        \"name\": \"recognize\",\n        \"help\": \"Recognize a single image\",\n        \"arguments\": [\n          {\n            \"name\": \"image\",\n            \"help\": \"Image path or URL\",\n            \"required\": true\n          },\n          {\n            \"name\": \"prompt\",\n            \"help\": \"Recognition prompt\",\n            \"required\": false,\n            \"default\": \"Please describe this image\"\n          }\n        ]\n      },\n      {\n        \"name\": \"chat\",\n        \"help\": \"Chat with Claude using image recognition\",\n        \"arguments\": [\n          {\n            \"name\": \"message\",\n            \"help\": \"User message\",\n            \"required\": true\n          }\n        ]\n      },\n      {\n        \"name\": \"batch\",\n        \"help\": \"Batch recognize multiple images\",\n        \"arguments\": [\n          {\n            \"name\": \"images\",\n            \"help\": \"Image paths or URLs\",\n            \"required\": true,\n            \"nargs\": \"+\"\n          }\n        ]\n      }\n    ]\n  },\n  \"repl\": {\n    \"enabled\": true,\n    \"entry_point\": \"interactive_shell.py\",\n    \"prompt\": \"🤖 Vision> \"\n  },\n  \"capabilities\": [\n    \"image-recognition\",\n    \"object-detection\",\n    \"scene-understanding\",\n    \"text-extraction\",\n    \"ocr\",\n    \"visual-question-answering\",\n    \"code-generation-from-ui\",\n    \"batch-processing\"\n  ],\n  \"supported_formats\": [\n    \"jpg\",\n    \"jpeg\",\n    \"png\",\n    \"gif\",\n    \"webp\"\n  ],\n  \"examples\": [\n    {\n      \"title\": \"Recognize a local image\",\n      \"command\": \"recognize ./photo.jpg 'What is in this image?'\"\n    },\n    {\n      \"title\": \"Recognize a web image\",\n      \"command\": \"recognize https://example.com/image.png 'Describe the scene'\"\n    },\n    {\n      \"title\": \"Chat with Claude\",\n      \"command\": \"chat 'Analyze this design: ./ui-design.png and generate React code'\"\n    },\n    {\n      \"title\": \"Batch process images\",\n      \"command\": \"batch image1.jpg image2.jpg image3.jpg\"\n    }\n  ],\n  \"documentation\": {\n    \"readme\": \"README.md\",\n    \"getting_started\": \"README.md#快速开始\",\n    \"api_reference\": \"README.md#api-参考\",\n    \"examples\": \"examples/\",\n    \"troubleshooting\": \"README.md#常见问题\"\n  },\n  \"metadata\": {\n    \"keywords\": [\n      \"vision\",\n      \"image-recognition\",\n      \"deepseek\",\n      \"claude\",\n      \"ai\",\n      \"skill\",\n      \"ocr\",\n      \"object-detection\",\n      \"code-generation\"\n    ],\n    \"category\": \"AI/Vision\",\n    \"rating\": 5,\n    \"downloads\": 0,\n    \"tags\": [\n      \"image-analysis\",\n      \"multi-modal\",\n      \"vision-language\"\n    ]\n  }\n}\n